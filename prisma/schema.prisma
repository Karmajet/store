generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  imageUrl    String
  price       Int         // base price in cents
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  variants    Variant[]
  orderItems  OrderItem[]
}

model Variant {
  id        String      @id @default(cuid())
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String      // e.g. "Size" or "Color"
  value     String      // e.g. "Large" or "Red"
  sku       String      @unique
  stock     Int         @default(0)
  priceDiff Int         @default(0) // additional cents on top of base price
  orderItems OrderItem[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  orders       Order[]
}

model Order {
  id              String      @id @default(cuid())
  stripeSessionId String      @unique
  stripePaymentId String?
  status          String      @default("pending") // pending, paid, failed
  email           String
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  shippingName    String
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingZip     String
  shippingCountry String
  totalAmount     Int         // cents
  createdAt       DateTime    @default(now())
  items           OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Int      // cents, snapshot at time of order
}

model AdminUser {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  name         String
}
