generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  products    Product[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  imageUrl    String
  price       Int         // base price in cents
  active      Boolean     @default(true)
  categoryId  String?
  category    Category?   @relation(fields: [categoryId], references: [id])
  createdAt   DateTime    @default(now())
  variants    Variant[]
  orderItems  OrderItem[]
  wishlist    Wishlist[]
  reviews     Review[]
}

model Variant {
  id        String      @id @default(cuid())
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String      // e.g. "Size" or "Color"
  value     String      // e.g. "Large" or "Red"
  sku       String      @unique
  stock     Int         @default(0)
  priceDiff Int         @default(0) // additional cents on top of base price
  orderItems OrderItem[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  resetToken       String?    @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime   @default(now())
  orders           Order[]
  wishlist         Wishlist[]
  reviews          Review[]
  addresses        Address[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   // e.g. "Home", "Work"
  name      String
  address   String
  city      String
  state     String
  zip       String
  country   String   @default("US")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Order {
  id              String      @id @default(cuid())
  stripeSessionId String      @unique
  stripePaymentId String?
  status          String      @default("pending") // pending, paid, failed
  email           String
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  shippingName    String
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingZip     String
  shippingCountry String
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  discountAmount  Int         @default(0) // cents
  subtotalAmount  Int         @default(0) // cents
  shippingMethod  String?
  shippingCost    Int         @default(0) // cents
  taxAmount       Int         @default(0) // cents
  totalAmount     Int         // cents (grand total)
  trackingNumber  String?
  notes           String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime    @default(now())
  items           OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Int      // cents, snapshot at time of order
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5
  title     String
  body      String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  type           String    // "percentage" or "fixed"
  value          Int       // percentage (e.g. 20 = 20%) or cents (e.g. 500 = $5)
  minOrderAmount Int?      // minimum order in cents to use coupon
  maxUses        Int?      // null = unlimited
  currentUses    Int       @default(0)
  active         Boolean   @default(true)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  orders         Order[]
}

model AdminUser {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  name         String
}
